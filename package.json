{
  "private": true,
  "name": "xu-harbor",
  "version": "1.0.0",
  "description": "A Vue 3 monorepo harbor for shared components, utilities, and frontend packages.",
  "scripts": {
    "prepare": "husky",
    "preinstall": "npx only-allow pnpm",
    "build": "turbo run build --log-order=grouped",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "release:prepare": "pnpm run lint:fix && pnpm run format && pnpm run build",
    "dev": "turbo run dev",
    "docs:dev": "turbo run dev --filter=@xu-harbor/docs",
    "docs:build": "turbo run build --filter=@xu-harbor/docs",
    "docs:preview": "turbo run preview --filter=@xu-harbor/docs",
    "publish-canary": "pnpm run release:prepare && lerna publish --canary --preid canary",
    "publish-beta": "pnpm run release:prepare && lerna publish --canary --preid beta",
    "publish-stable": "pnpm run release:prepare && lerna publish"
  },
  "lint-staged": {
    "packages/cli/**/*.ts": [
      "eslint --fix --config packages/cli/eslint.config.mjs",
      "prettier --write"
    ],
    "packages/proComponents/**/*.{ts,tsx,vue}": [
      "eslint --fix --config packages/proComponents/eslint.config.mjs",
      "prettier --write"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ],
    "packages/**/*.{md,json,mjs,css,scss}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.33.4",
  "devDependencies": {
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "lint-staged": "^17.0.7",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.4",
    "turbo": "^2.9.18"
  }
}
