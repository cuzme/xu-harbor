{
  "name": "@yobiccc/pro-components",
  "version": "0.0.3",
  "description": "Use Element Plus components in your project",
  "license": "MIT",
  "author": "xu.zhu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuzme/xu-harbor.git",
    "directory": "packages/proComponents"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./lib/index.cjs",
  "module": "./es/index.mjs",
  "types": "./es/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./es/index.d.ts",
        "default": "./es/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.cjs"
      }
    },
    "./style.css": {
      "import": "./es/pro-components.css",
      "require": "./lib/pro-components.css"
    }
  },
  "files": [
    "es",
    "lib"
  ],
  "scripts": {
    "build": "pnpm run clean && vite build",
    "clean": "rimraf ./dist ./es ./lib ./types",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "pnpm run lint:fix && pnpm run format && pnpm run build"
  },
  "peerDependencies": {
    "@element-plus/icons-vue": "^2.0.0",
    "@vueuse/core": "^14.0.0",
    "element-plus": "^2.0.0",
    "lodash-es": "^4.17.21",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@eslint/js": "^10.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/language-core": "^3.3.5",
    "@vueuse/core": "^14.3.0",
    "element-plus": "^2.14.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "lodash-es": "^4.18.1",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "rollup-plugin-pure": "^0.4.0",
    "sass-embedded": "^1.100.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vue": "^3.5.38",
    "vue-eslint-parser": "^10.4.1"
  }
}
