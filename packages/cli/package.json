{
  "name": "@yobiccc/cli",
  "version": "0.0.1",
  "description": "快速构建前端相关项目的命令行脚手架",
  "type": "module",
  "license": "MIT",
  "author": "xu.zhu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuzme/xu-harbor.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "yobi": "bin/cli.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf ./dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "boxen": "^7.1.1",
    "cac": "^6.7.14",
    "figlet": "^1.7.0",
    "gradient-string": "^2.0.2",
    "inquirer": "^9.2.21",
    "log-symbols": "^6.0.0",
    "ora": "^8.0.1",
    "picocolors": "^1.0.1",
    "progress-estimator": "^0.3.1",
    "semver": "^7.6.2",
    "simple-git": "^3.24.0",
    "trash": "^8.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/figlet": "^1.5.8",
    "@types/gradient-string": "^1.1.6",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^26.0.1",
    "@types/semver": "^7.5.8",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "tsup": "^8.0.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
